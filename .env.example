# ─── App ───────────────────────────────────────────
APP_NAME=AI-IDS
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
VERCEL=false

# ─── Server ────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4

# ─── PostgreSQL ────────────────────────────────────
# Local / Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aids
POSTGRES_PASSWORD=aids_secret_2024
POSTGRES_DB=aids_db

# Vercel Postgres (overrides individual POSTGRES_* vars)
# Vercel automatically sets this after you link a Postgres database
# DATABASE_URL=postgres://default:xxx@ep-xxx-pooler.us-east-1.aws.neon.tech:5432/verceldb?sslmode=require&pgbouncer=true

# ─── Auth / JWT ────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-very-long-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Frontend (used at build time) ─────────────────
# Set this to your backend URL when deploying frontend as a static site
# e.g. VITE_API_URL=https://your-backend.onrender.com/api/v1
# Leave as /api/v1 when backend serves frontend (single service)
# VITE_API_URL=/api/v1

# ─── CORS ──────────────────────────────────────────
CORS_ORIGINS=["*"]

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── ML ────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.85
ML_MODEL_PATH=trained_models/best_model.pkl
FEATURE_CACHE_SIZE=1000
ENABLE_REALTIME_PREDICTION=true
ENABLE_AUTO_RETRAINING=false
RETRAINING_INTERVAL_HOURS=24

# ─── Packet Capture ────────────────────────────────
ENABLE_PACKET_CAPTURE=false
MAX_PACKET_CAPTURE_SIZE=65535
PACKET_BUFFER_SIZE=10000
FLOW_IDLE_TIMEOUT=60
FLOW_LIFETIME=3600

# ─── Notifications ─────────────────────────────────
ENABLE_NOTIFICATIONS=true
FIREBASE_CREDENTIALS_PATH=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
