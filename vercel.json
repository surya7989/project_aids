{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@3.0.0",
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" }
  ],
  "env": {
    "ENVIRONMENT": "production",
    "DEBUG": "false",
    "CORS_ORIGINS": "[\"*\"]",
    "LOG_LEVEL": "INFO",
    "LOG_FORMAT": "json"
  },
  "github": {
    "silent": true
  }
}
